# Prisma connection string. SQLite for local dev.
DATABASE_URL="file:./dev.db"

# Required in production — HMAC key for signing session cookies.
# Generate with: openssl rand -hex 32
# SESSION_SECRET=""

# Optional overrides for the seeded admin user (pnpm db:seed).
# SEED_ADMIN_EMAIL="admin@store2door.rw"
# SEED_ADMIN_PASSWORD="admin123"
